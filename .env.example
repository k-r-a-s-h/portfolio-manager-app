# ── LLM Provider ──────────────────────────────────────────────────────────────
# Which LLM backend to use. Supported: "openai" | "anthropic"
LLM_PROVIDER=openai

# Optional: override the default model for the chosen provider.
# openai default    → gpt-4o-mini
# anthropic default → claude-3-5-haiku-latest
# LLM_MODEL=gpt-4o

# ── API Keys ───────────────────────────────────────────────────────────────────
# Set the key that matches your LLM_PROVIDER (the other can be left blank).
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
