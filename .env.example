# Server
PORT=3000
NODE_ENV=development

# LLM Model Selection — format: "provider/model-name"
# Examples: anthropic/claude-3-5-sonnet-20241022, openai/gpt-4o, openai/gpt-4o-mini
LLM_MODEL=anthropic/claude-3-5-sonnet-20241022

# Provider API Keys — set the one matching your LLM_MODEL provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
